<div class="card-content hag-grant-water-breathing-card"
     data-transformations-card="true"
     data-hag-activity="{{activityId}}"
     data-state="{{state}}">

    {{#if roll}}
        <div class="dice-roll">
            <div class="dice-result">
                <div class="dice-formula">{{rollFormula}}</div>
                {{{tooltip}}}
                <h4 class="dice-total">{{roll}}</h4>
            </div>
        </div>
    {{else}}
        <p>Roll {{rollFormula}} to determine the duration in minutes.</p>
    {{/if}}

    <div class="card-buttons">
        {{#if (eq state "initial")}}
            <button type="button"
                    class="dnd5e-button"
                    data-transformations-action="rollDuration">
                Roll Duration
            </button>
        {{/if}}
    </div>
</div>
