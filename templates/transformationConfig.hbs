<div class="transformation-config-wrapper">
    <section class="flexcol transformation-config">
        <div class="final-value">{{ preview }}</div>
        <fieldset class="card">
            <legend>Transformation</legend>
            <ol class="unlist form-grid form-grid-50 types-list" style="--type-rows: {{ rows }};">
                {{#each transformations as |t|}}
                <li style="display: flex; justify-content: right;" class="type-row">
                    <label for="transformation-type-{{t.id}}">
                        <span>{{t.name}}</span>
                        <input type="radio" name="transformation" value="{{t.id}}" {{#if t.selected}}checked{{/if}} {{#unless ../editable}}disabled{{/unless}}>
                    </label>
                </li>
                {{/each}}
                <li style="display: flex; justify-content: right;" class="type-row none">
                    <label for="transformation-type-none">
                        <span>None</span>
                        <input type="radio" name="transformation" value="None" id="transformation-type-none" {{#if noneSelected}}checked{{/if}} {{#unless editable}}disabled{{/unless}}>
                    </label>
                </li>
            </ol>
        </fieldset>
    </section>

    <section style="margin-top:10px; display: flex; justify-content: center;" class="flexcol transformation-stage-config">
        <fieldset class="card">
            <legend>Transformation Stage</legend>
            <div class="form-group">
                <p>Curent Stage: {{transformationStage}}</p>
            </div>
        </fieldset>
    </section>
    
    <footer style="margin-top:10px; display: flex; justify-content: center;" class="sheet-footer">
        {{#if editable}}
        <button type="submit" data-action="save">
            Add Transformation
        </button>
        {{else}}
        <button type="submit" disabled data-tooltip="Transformation can't be changed">
            Add Transformation
        </button>
        {{/if}}
        {{#if canLevelUpStage}}
        <button type="submit" data-action="stageUp">
            Level up transformation stage
        </button>
        {{else}}
        <button type="submit" disabled data-tooltip="Transformation has Reached hihgest stage">
            Level up transformation stage
        </button>
        {{/if}}
    </footer>
</div>