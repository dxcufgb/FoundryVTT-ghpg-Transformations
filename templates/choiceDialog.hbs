<div class="choice-wrapper">
	<div class="choice-container">
		{{#each choices}}
			<button class="choice-card-button" data-action="save" data-choice-name="{{name}}">
				<div class="choice-tooltip">
				<p>Right-click to view info</p>
				</div>

				<div class="choice-context-tooltip">
				{{{details}}}
				</div>

				<img src="{{icon}}" alt="{{name}}">
				<h4>{{name}}</h4>
			</button>
		{{/each}}
	</div>
</div>