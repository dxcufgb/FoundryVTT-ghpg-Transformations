<div class="transformation-general-choices-wrapper">
    <div class="transformation-general-choices-content">
        {{#if isMultiChoice}}
            <div
                class="transformation-general-choices-counter"
                data-choice-counter>
                Choices left: <span data-choice-counter-value>{{choicesLeft}}</span>
            </div>
        {{/if}}

        {{#if description}}
            <div class="transformation-general-choices-description">
                {{{description}}}
            </div>
        {{/if}}

        <div class="transformation-general-choices">

            <ol class="choices-list">

                {{#each choices as |type|}}
                <li class="type-row choice-option">

                    <button
                        type="button"
                        class="choice-button"
                        data-choice-id="{{type.id}}"
                        aria-pressed="false">

                        <img
                            class="choice-image"
                            src="{{type.icon}}"
                            alt="{{type.label}}">

                        <span class="choice-label">
                            {{type.label}}
                        </span>

                    </button>

                </li>
                {{/each}}

            </ol>

        </div>
        {{#if isMultiChoice}}
            <div class="transformation-general-choice-footer">
                <button
                    type="button"
                    class="choice-confirm"
                    data-action="choose"
                    disabled>
                    Make choice
                </button>
            </div>
        {{/if}}
    </div>
</div>
