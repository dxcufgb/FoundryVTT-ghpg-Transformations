<div class="transformation-config-wrapper">
    <section class="flexcol transformation-config">
        <div class="final-value">{{ preview }}</div>
        <fieldset class="card">
            <ol class="unlist form-grid form-grid-50 types-list" style="--type-rows: {{ rows }};">
                {{#each transformations as |t|}}
                <li class="type-row">
                    <label>
                        <img style="height:40px" class="gold-icon" src="{{t.img}}" alt="{{t.name}}">
                        <span>{{t.name}}</span>
                        <input type="radio" name="transformation value="{{t.uuid}}" {{#if t.selected}}checked{{/if}} {{#unless ../editable}}disabled{{/unless}}>
                    </label>
                </li>
                {{/each}}
                <li class="type-row none">
                    <label for="transformation-type-none">
                        <input type="radio" name="transformation" value="None" id="">
                    </label>
                </li>
            </ol>
        </fieldset>
    </section>
    
    <footer class="sheet-footer">
        {{#if editable}}
        <button type="submit" data-action="save">
            Apply
        </button>
        {{else}}
        <p class="notes">You do not have permission to edit this.</p>
        {{/if}}
    </footer>
</div>