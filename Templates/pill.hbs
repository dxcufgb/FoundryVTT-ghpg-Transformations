<div class="draggable pill-lg texture transformation item-tooltip" data-action="showDocument"
        data-item-id="{{ transformation.id }}" data-uuid="{{ transformation.uuid }}"
        aria-label="{{ localize (ifThen actor.isOwner DND5E.ItemEdit DND5E.ItemView) }}">
    {{#if transformation.img}}
    <img class="gold-icon" src="{{ transformation.img }}" alt="{{ transformation.name }}">
    {{/if}}
    <div class="name name-stacked">
        <span class="title">{{ transformation.name }}</span>
        <span class="subtitle">stage {{ transformation.transformationLevel }}</span>
    </div>
    {{#if editable}}
    <button type="button" class="config-button unbutton" data-action="showConfiguration" data-config="tansformation" data-tooltip="DND5E.CreatureTypeConfig" aria-label="Configure Transformation">
        <i class="fas fa-cog" inert=""></i>
    </button>
    {{/if}}
</div>